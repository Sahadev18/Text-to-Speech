<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/login.css">
    <title>Login</title>
</head>
<body>
    <div class="login">
        <form action="/login" method="post">
            <h1>Login</h1>
            <div class="mail" style="display: flex; background-color: white;">
                <p style="background-color: white;">Email:</p>
                <input type="text" style="background-color: white;">
            </div>
            <div class="pass" style="display: flex; background-color: white;">
                <p style="background-color: white;">Password:</p>
                <input type="password" style="background-color: white;">
            </div>
            <input type="submit" class="btn1" value="Login">
        </form>
        <a href="/"><button class="btn2">Cancel</button></a>
        {{#if message1}}
            <b><h4>{{message1}}</h4></b>
        {{/if}}
    </div>
    
</body>
</html>