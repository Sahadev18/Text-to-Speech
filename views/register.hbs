<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/register.css">
    <title>Login</title>
</head>
<body>
    <div class="registration">
        <form action="/register" method="post">
            <h1>Registration</h1>
            <div class="name" style="display: flex; background-color: white;">
                <p style="background-color: white;">Name:</p>
                <input type="text" style="background-color: white;" name="name">
            </div>
            <div class="mail" style="display: flex; background-color: white;">
                <p style="background-color: white;">Email:</p>
                <input type="text" style="background-color: white;" name="email">
            </div>
            <div class="phone" style="display: flex; background-color: white;">
                <p style="background-color: white;">Phone No:</p>
                <input type="text" style="background-color: white;" name="phno">
            </div>
            <div class="pass" style="display: flex; background-color: white;">
                <p style="background-color: white;">Password:</p>
                <input type="password" style="background-color: white;" name="pass">
            </div>
            <div class="cpass" style="display: flex; background-color: white;">
                <p style="background-color: white;">Confirm Password:</p>
                <input type="password" style="background-color: white;" name="cpass">
            </div>
            <input type="submit" class="btn1" value="Register">
        </form>
        <a href="/"><button class="btn2">Cancel</button></a>
            {{#if message}}
                <b><h4 style="color: red;">{{message}}</h4></b>
            {{/if}}
            {{#if message1}}
                <b><h4 style="color: green;">{{message1}}</h4></b>
            {{/if}}
    </div>
</body>
</html>